# === LLM Provider ===
# "ollama" for local dev (default), "groq" for production
LLM_PROVIDER=ollama

# === Groq API (required when LLM_PROVIDER=groq) ===
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# === Together.ai Image Generation (optional, for Phase 5) ===
# Get your key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

# === CORS ===
# Set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:3000

# === Server (Render sets PORT automatically) ===
PORT=8000
